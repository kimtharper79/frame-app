# Copy this file to .env and fill in your Firebase project values.
# Find these in: Firebase Console → Project Settings → Your apps → Web app → SDK setup

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# The full URL of your deployed GitHub Pages site (with trailing slash).
# Firebase sends this as the magic-link return URL after email sign-in.
# Example: https://yourusername.github.io/frame-app/
VITE_APP_URL=
